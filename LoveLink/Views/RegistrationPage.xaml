<?xml version="1.0" encoding="utf-8"?>

<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="LoveLink.Views.RegistrationPage"
             Title="Sign Up">
    
    <StackLayout Spacing="10" VerticalOptions="CenterAndExpand" HorizontalOptions="FillAndExpand" Padding="10">
        <Entry Placeholder="Email" Keyboard="Email" Text="{Binding Email}"></Entry>
        <Entry Placeholder="Password" IsPassword="True" Text="{Binding Password}"></Entry>
        <Button Text="SIGN UP" Command="{Binding RegisterButton}"></Button>
    </StackLayout>
    
</ContentPage>